<section class="our-events-section-3 p-t-120 p-t-md-100 p-t-xs-80 p-b-160 p-b-lg-120 p-b-md-100 p-b-xs-80">
		<div class="container text-center">
			<div class="text-center m-b-50 m-b-xs-40">
				<div class="common-subtitle text-uppercase" data-aos="fade-up" data-aos-delay="200" data-aos-duration="1000">
					<img alt="icon-2" src="assets/img/icons/icon-2.svg"> <span>Upcoming Event</span>
				</div>
				<div class="common-title m-b-0 text-center" data-aos="fade-up" data-aos-delay="400" data-aos-duration="1000">
					<h2>Our Events, Let's <img alt="icon-2" src="assets/img/icons/icon-2.svg"> All Participate</h2>
				</div>
			</div>
			<div class="row row-gap-4" data-aos="fade-up" data-aos-delay="600" data-aos-duration="1000">
				<% if (typeof events !== 'undefined' && events.length > 0) { %>
					<% events.forEach(function(event) { %>
						<% const e = event.data; %>
						<% const eventDate = new Date(e.date); %>
						<% const day = eventDate.getDate(); %>
						<% const month = eventDate.toLocaleString('default', { month: 'long' }); %>
						<% const year = eventDate.getFullYear(); %>
						<div class="col-lg-6 col-12">
							<div class="event-card">
								<div class="thumb">
									<a href="/events/<%= e.slug %>"><img alt="<%= e.name %>" src="<%= e.thumbnail?.url || 'assets/img/thumbs/thumb-102.webp' %>"></a>
								</div>
								<div class="card-content">
									<div class="event-card-top p-t-20">
										<div class="top-left">
											<img alt="calendar-icon" src="assets/img/icons/calendar-2.svg">
											<div class="event-date">
												<h3><%= day %> <span><%= month %><br>in <%= year %></span></h3>
											</div>
										</div>
									</div>
									<div class="event-card-middle text-start">
										<h2><%= e.name %></h2>
										<div class="address">
											<% if (e.location) { %>
												<div class="location">
													<i class="fa-regular fa-location-dot"></i> <span><%= e.location %></span>
												</div>
											<% } %>
											<% if (e.time) { %>
												<div class="time">
													<i class="fa-regular fa-clock"></i> <span><%= e.time %></span>
												</div>
											<% } %>
										</div>
										<div class="event-btn">
											<a class="e-primary-btn has-icon" href="<%= e.cta_link || '/events/' + e.slug %>">
												<%= e.cta_text || 'Join Event' %>
												<span class="icon-wrap"><span class="icon"><i class="fa-regular fa-arrow-right"></i><i class="fa-regular fa-arrow-right"></i></span></span>
											</a>
										</div>
									</div>
								</div>
							</div>
						</div>
					<% }); %>
				<% } %>
			</div>
		</div>
		<div class="shape"><img alt="shape" src="assets/img/shapes/shape-40.webp"></div>
	</section>